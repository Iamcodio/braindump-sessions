#!/usr/bin/env bash
# braindump-eod — End of day processor (standalone, no caveman dependency)
# Reads today's entries from braindump.db, classifies via 4D framework,
# saves archive + exchange files
set -euo pipefail

BD_DIR="$HOME/09-personal/BrainDumpSessions"
DB="$BD_DIR/braindump.db"
TODAY=$(date +%Y-%m-%d)
MONTH=$(date +%Y-%m)
ARCHIVE_DIR="$BD_DIR/sessions/$MONTH"
EXCHANGE_DIR="$HOME/caveman/collab/braindump-exchange"
EOD_TEMPLATE="$BD_DIR/templates/end_of_day_prompt.md"

export PATH="$HOME/.local/bin:$HOME/.nvm/versions/node/$(ls "$HOME/.nvm/versions/node/" 2>/dev/null | tail -1)/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

mkdir -p "$ARCHIVE_DIR" "$EXCHANGE_DIR/summaries" "$EXCHANGE_DIR/ideas" "$EXCHANGE_DIR/tasks"

# Extract today's entries
ENTRIES=$(sqlite3 "$DB" "SELECT timestamp, raw_text FROM entries WHERE date='$TODAY' ORDER BY created_at ASC;" 2>/dev/null)
BASELINES=$(sqlite3 "$DB" "SELECT * FROM baselines WHERE date='$TODAY' ORDER BY id DESC LIMIT 1;" 2>/dev/null)

if [ -z "$ENTRIES" ]; then
    echo "No entries for $TODAY. Nothing to process."
    exit 0
fi

ENTRY_COUNT=$(sqlite3 "$DB" "SELECT COUNT(*) FROM entries WHERE date='$TODAY';")
echo "Processing $ENTRY_COUNT entries for $TODAY..."

# Write prompt to temp file (avoids bash mangling special chars)
PROMPT_FILE=$(mktemp)
echo "Process today's brain dump ($TODAY). $ENTRY_COUNT entries." > "$PROMPT_FILE"
echo "" >> "$PROMPT_FILE"
echo "--- TODAY'S ENTRIES ---" >> "$PROMPT_FILE"
echo "$ENTRIES" >> "$PROMPT_FILE"
echo "" >> "$PROMPT_FILE"
[ -n "$BASELINES" ] && echo "--- BASELINE DATA ---" >> "$PROMPT_FILE" && echo "$BASELINES" >> "$PROMPT_FILE"

# Load EOD template if exists
TEMPLATE=""
[ -f "$EOD_TEMPLATE" ] && TEMPLATE=$(cat "$EOD_TEMPLATE")

# Build system prompt file
SYSTEM_FILE=$(mktemp)
cat > "$SYSTEM_FILE" << 'SYSEOF'
This is a headless claude -p call. Do NOT use antArtifact XML tags or filesystem tools.
Output the complete markdown archive directly as plain text. ASCII ONLY — no emojis.
SYSEOF
[ -n "$TEMPLATE" ] && echo "$TEMPLATE" >> "$SYSTEM_FILE"

# Run classification via claude -p
PROMPT_TEXT=$(cat "$PROMPT_FILE")
SYSTEM_TEXT=$(cat "$SYSTEM_FILE")
RESULT=$(claude -p "$PROMPT_TEXT" \
    --model claude-sonnet-4-6 \
    --output-format json \
    --dangerously-skip-permissions \
    --max-turns 5 \
    --append-system-prompt "$SYSTEM_TEXT" 2>/dev/null)
rm -f "$PROMPT_FILE" "$SYSTEM_FILE"

# Extract result text
ARCHIVE_TEXT=$(echo "$RESULT" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('result',''))" 2>/dev/null)

if [ -z "$ARCHIVE_TEXT" ]; then
    echo "ERROR: No result from claude"
    exit 1
fi

# Save archive
ARCHIVE_FILE="$ARCHIVE_DIR/${TODAY}_brain_dump_archive.md"
echo "$ARCHIVE_TEXT" > "$ARCHIVE_FILE"
echo "Archive saved: $ARCHIVE_FILE"

# Extract summary for exchange (first 500 chars of daily summary section)
SUMMARY=$(echo "$ARCHIVE_TEXT" | sed -n '/DAILY SUMMARY/,/^---/p' | head -20)
[ -n "$SUMMARY" ] && echo "# Daily Summary - $TODAY\n\n$SUMMARY" > "$EXCHANGE_DIR/summaries/$TODAY.md"

# Extract actionable items for exchange
TASKS=$(echo "$ARCHIVE_TEXT" | sed -n '/ACTIONABLE ITEMS/,/^---/p' | grep '^\- \[' || true)
[ -n "$TASKS" ] && echo "# Tasks - $TODAY\n\n$TASKS" > "$EXCHANGE_DIR/tasks/$TODAY.md"

echo "EOD complete for $TODAY."
echo "  Archive: $ARCHIVE_FILE"
echo "  Exchange: $EXCHANGE_DIR/summaries/$TODAY.md"
